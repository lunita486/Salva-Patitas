rules_version = '2';

// Ver ARCHITECTURE.md para el razonamiento completo. Resumen: esta es la
// barrera real de seguridad — el filtrado del lado del cliente (en Dart)
// es solo para no traer datos de más, nunca hay que asumir que alcanza.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function myRoles() {
      return signedIn()
        ? get(/databases/$(database)/documents/usuarios/$(uid())).data.get('roles', [])
        : [];
    }

    function hasRole(r) {
      return signedIn() && r in myRoles();
    }

    // Como `rescatistaId` en un chat puede ser un uid distinto al que está
    // escribiendo (ej. el adoptante crea el chat, pero el rol que se valida
    // es el del rescatista/albergue del otro lado), no alcanza con hasRole().
    function tieneRol(elUid, rol) {
      return signedIn() &&
        rol in get(/databases/$(database)/documents/usuarios/$(elUid)).data.get('roles', []);
    }

    // ── usuarios ──────────────────────────────────────────────────────
    // Perfil de cuenta. Hay pantallas públicas (albergue_publico_screen,
    // aliado_publico_screen) que leen el perfil de OTRO usuario, así que
    // la lectura es abierta a cualquiera logueado. La escritura es solo
    // del dueño, y si toca `roles`, se valida contra la lista permitida
    // (antes cualquier cliente podía escribir cualquier string ahí).
    match /usuarios/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && uid() == userId &&
        (!('roles' in request.resource.data) ||
          request.resource.data.roles.hasOnly(['adoptante', 'rescatista', 'albergue', 'aliado']));
    }

    // ── rescates ──────────────────────────────────────────────────────
    // Catálogo de adopción — lectura pública, INCLUYE lat/long exacta.
    // Decisión consciente (no un descuido): que se pueda ver sin cuenta
    // ayuda a que se comparta y a que gente sin la app decida entrar.
    // Escritura solo del dueño, y `creadoPor` tiene que coincidir con un
    // rol de cuenta que ese uid realmente tenga (no puede publicar como
    // 'albergue' si su cuenta nunca activó ese rol).
    match /rescates/{rescateId} {
      allow read: if true;
      allow create: if signedIn() &&
        request.resource.data.rescatistaId == uid() &&
        request.resource.data.creadoPor in ['rescatista', 'albergue'] &&
        hasRole(request.resource.data.creadoPor);
      allow update, delete: if signedIn() && resource.data.rescatistaId == uid();
    }

    // ── solicitudes ───────────────────────────────────────────────────
    // Privado: contiene datos de vivienda/familia del adoptante. Solo lo
    // ven el adoptante dueño y el rescatista/albergue destinatario.
    match /solicitudes/{solicitudId} {
      allow read: if signedIn() &&
        (resource.data.adoptanteId == uid() || resource.data.rescatistaId == uid());
      allow create: if signedIn() && request.resource.data.adoptanteId == uid();
      // Solo el rescatista/albergue dueño del animal puede cambiar el
      // estado (aprobar/rechazar) — el adoptante lee su propia solicitud
      // pero nunca la escribe después de creada. Antes cualquiera de las
      // dos partes podía hacer update() sin que la regla restringiera qué
      // campo cambiaba: un adoptante podía escribir estado:'aprobada' en
      // su propia solicitud (no podía tocar el animal, pero sí falsear el
      // estado y disparar el push de "¡tu solicitud fue aprobada!" sin que
      // nadie del otro lado la hubiera aprobado en realidad).
      allow update: if signedIn() &&
        resource.data.rescatistaId == uid() &&
        resource.data.estado == 'pendiente' &&
        request.resource.data.estado in ['aprobada', 'rechazada'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'motivoRechazo']);
    }

    // ── preferencias ──────────────────────────────────────────────────
    // Antes: un único documento fijo compartido por todos ("adoptante").
    // Ahora el id del documento es el uid — cada quien ve/edita el suyo.
    // También vive acá `perfilAdopcion` (vivienda, niños, mascotas, horas
    // fuera de casa) — es sensible y antes se guardaba en `usuarios/{uid}`,
    // que es de lectura pública para cualquier usuario logueado.
    match /preferencias/{userId} {
      allow read, write: if signedIn() && uid() == userId;
    }

    // ── favoritos ─────────────────────────────────────────────────────
    match /favoritos/{favId} {
      allow read, delete: if signedIn() && resource.data.adoptanteId == uid();
      allow create: if signedIn() && request.resource.data.adoptanteId == uid();
      allow update: if signedIn() && resource.data.adoptanteId == uid() &&
        request.resource.data.adoptanteId == uid();
    }

    // ── chats ─────────────────────────────────────────────────────────
    // Un chat identifica a sus dos dueños (adoptanteId/rescatistaId). Los
    // chats sobre un animal además llevan `creadoPor` (rescatista/albergue)
    // para separar bandejas en cuentas con doble rol. Y, como en
    // `solicitudes`, los campos de identidad no se pueden reescribir después.
    //
    // La validación de `creadoPor` está anclada al documento REAL de
    // `rescates` (rescatistaId + creadoPor deben coincidir con ese animal),
    // no al rol ACTUAL de la cuenta — antes usaba tieneRol() para revisar
    // los roles de hoy de rescatistaId, y una cuenta que alguna vez publicó
    // como 'albergue' pero después cambió sus roles (ej. dejó de ser
    // albergue) quedaba con todos sus animales viejos huérfanos: ningún
    // adoptante podía volver a abrirles un chat nuevo, aunque el animal
    // siguiera publicado y visible en el feed. Esto pasó de verdad: un
    // rescate quedó con creadoPor:'albergue' apuntando a una cuenta cuyos
    // roles ya no incluían 'albergue', y "Hacer una pregunta" tiraba
    // permission-denied en silencio.
    //
    // Una consulta a un ALIADO (tipoSolicitud 'consulta_aliado') también usa
    // `creadoPor` para separar la bandeja de rescatista y de albergue — pero
    // ahí rescatistaId es siempre el aliado (nunca tiene rol
    // rescatista/albergue), y quien realmente tiene ese rol es adoptanteId
    // (quien contactó). No hay rescate contra el cual anclar, así que se
    // valida con tieneRol() sobre adoptanteId en vez de rescatistaId.
    match /chats/{chatId} {
      allow read: if signedIn() &&
        (resource.data.adoptanteId == uid() || resource.data.rescatistaId == uid());
      allow create: if signedIn() &&
        (request.resource.data.adoptanteId == uid() || request.resource.data.rescatistaId == uid()) &&
        (!('creadoPor' in request.resource.data) ||
          (request.resource.data.creadoPor in ['rescatista', 'albergue'] &&
           (
             (request.resource.data.get('rescateId', '') != '' &&
              get(/databases/$(database)/documents/rescates/$(request.resource.data.rescateId)).data.rescatistaId == request.resource.data.rescatistaId &&
              get(/databases/$(database)/documents/rescates/$(request.resource.data.rescateId)).data.creadoPor == request.resource.data.creadoPor)
             ||
             (request.resource.data.get('tipoSolicitud', '') == 'consulta_aliado' &&
              tieneRol(request.resource.data.adoptanteId, request.resource.data.creadoPor))
             ||
             // Fallback legado, sin rescateId ni consulta_aliado (ver
             // chat_screen.dart): no hay documento de rescate contra el
             // cual anclar, así que se mantiene el chequeo de rol actual
             // como antes.
             (request.resource.data.get('rescateId', '') == '' &&
              request.resource.data.get('tipoSolicitud', '') != 'consulta_aliado' &&
              tieneRol(request.resource.data.rescatistaId, request.resource.data.creadoPor))
           )));
      allow update: if signedIn() &&
        request.resource.data.adoptanteId == resource.data.adoptanteId &&
        request.resource.data.rescatistaId == resource.data.rescatistaId &&
        request.resource.data.get('creadoPor', null) == resource.data.get('creadoPor', null) &&
        (resource.data.adoptanteId == uid() || resource.data.rescatistaId == uid());

      match /mensajes/{mensajeId} {
        allow read: if signedIn() &&
          (get(/databases/$(database)/documents/chats/$(chatId)).data.adoptanteId == uid() ||
           get(/databases/$(database)/documents/chats/$(chatId)).data.rescatistaId == uid());
        allow create: if signedIn() &&
          (get(/databases/$(database)/documents/chats/$(chatId)).data.adoptanteId == uid() ||
           get(/databases/$(database)/documents/chats/$(chatId)).data.rescatistaId == uid());
      }
    }

    // ── servicios ─────────────────────────────────────────────────────
    // Catálogo de negocios aliados — lectura pública, escritura solo del
    // aliado dueño.
    match /servicios/{servicioId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.aliadoId == uid() && hasRole('aliado');
      allow update, delete: if signedIn() && resource.data.aliadoId == uid();
    }

    // ── solicitudes_rescatista ────────────────────────────────────────
    // Pantalla "volverme rescatista verificado" — no está enlazada desde
    // ninguna navegación hoy (código huérfano). Se bloquea por completo
    // a propósito hasta que alguien la conecte y le agregue su propia regla.
    match /solicitudes_rescatista/{docId} {
      allow read, write: if false;
    }
  }
}
